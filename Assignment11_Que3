# Q3. Write a python program which accepts one number and prints sum of digits.

def SumDigits(No):

    Sum = 0

    for Digit in str(No):
        Sum = Sum + int(Digit)

    return Sum


def main():
    Value = int(input("Enter number : "))

    Ret = SumDigits(Value)

    print("Sum of digits is :", Ret)


if __name__ == "__main__":
    main()